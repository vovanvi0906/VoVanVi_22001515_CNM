<%- include('../partials/header') %>

<% if (message) { %>
  <p class="success"><%= message %></p>
<% } %>

<a href="/products/create" class="btn">Thêm sản phẩm</a>

<table border="1" cellpadding="10" cellspacing="0" width="100%">
  <thead>
    <tr>
      <th>Ảnh</th>
      <th>Tên</th>
      <th>Giá</th>
      <th>Tồn kho</th>
      <th>Hành động</th>
    </tr>
  </thead>
  <tbody>
    <% if (products.length === 0) { %>
      <tr>
        <td colspan="5">Chưa có sản phẩm nào</td>
      </tr>
    <% } %>

    <% products.forEach(product => { %>
      <tr>
        <td>
          <% if (product.url_image) { %>
            <img src="<%= product.url_image %>" width="80">
          <% } %>
        </td>
        <td><%= product.name %></td>
        <td><%= product.price %></td>
        <td><%= product.unit_in_stock %></td>
        <td>
          <a href="/products/<%= product.id %>">Chi tiết</a> |
          <a href="/products/<%= product.id %>/edit">Sửa</a> |
          <form action="/products/<%= product.id %>?_method=DELETE" method="POST" style="display:inline;">
            <button type="submit" onclick="return confirm('Bạn có chắc muốn xóa?')">Xóa</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>